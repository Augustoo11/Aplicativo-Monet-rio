{
  "name": "Expo React Native (Java 17)",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "features": {
    "ghcr.io/devcontainers/features/java:1": {
      "version": "17"
    }
  },

  "postCreateCommand": "npm ci --legacy-peer-deps && node -v && java -version",

  "forwardPorts": [8081, 19000, 19001, 19002, 8080],

  "portsAttributes": {
    "8081": {
      "label": "Expo Metro Bundler",
      "onAutoForward": "notify"
    },
    "19000": {
      "label": "Expo (Tunel)",
      "onAutoForward": "notify"
    },
    "8080": {
      "label": "Backend - GestorFin",
      "onAutoForward": "notify"
    }
  }
}